# ===== ModelScope（LLM + 可选 embedding）=====
# 在 https://modelscope.cn 的「访问令牌」页面获取
MODELSCOPE_API_KEY=your_modelscope_token_here
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
# LLM 模型（实测可用：deepseek-ai/DeepSeek-V3.2，中文强、免费）
# 可用模型列表见 ModelScope API-Inference 文档
LLM_MODEL=deepseek-ai/DeepSeek-V3.2
# 模型故障转移链（逗号分隔）：首选模型 429 配额超限时按序自动切换，用户无感知。
# ModelScope 免费配额按模型分别计算（每模型约 20 次/天）。留空则用代码内置默认链。
# LLM_FALLBACK_MODELS=Qwen/Qwen3-235B-A22B-Instruct-2507,ZhipuAI/GLM-5,deepseek-ai/DeepSeek-V4-Flash

# ===== Embedding 供应商切换 =====
# 可选值：modelscope | siliconflow
# 注意：ModelScope 免费 embedding 额度限制较严，实测推荐用 siliconflow
EMBEDDING_PROVIDER=siliconflow

# ModelScope embedding（若其 /v1/embeddings 可用）
MODELSCOPE_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B

# ===== SiliconFlow（embedding 推荐，国内可访问、免费额度充足）=====
# 在 https://cloud.siliconflow.cn 的「API 密钥」页面获取
SILICONFLOW_API_KEY=your_siliconflow_token_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBED_MODEL=BAAI/bge-m3

# ===== 检索参数 =====
TOP_K=8

# ===== 混合检索（向量 + BM25 关键词，RRF 融合）=====
# 向量擅长语义、BM25 擅长法律术语精确匹配，两路融合提升召回。
HYBRID_ENABLED=true
HYBRID_CANDIDATES=20
# RRF 融合常数，越小则排名靠前项权重越大
RRF_K=10
# 两路权重：向量召回质量高，给更高权重，BM25 只补召回不主导 top 排名
HYBRID_VECTOR_WEIGHT=5.0
HYBRID_BM25_WEIGHT=1.0

# ===== 相关性闸门 =====
# 若最相关条文的向量余弦距离仍大于此值，判定问题与民法典无关，返回"未找到相关条文"。
# 实测：真实法律问题 distance≈0.6~0.9，无关问题（天气/菜谱）≥1.2。设 0 关闭。
MAX_DISTANCE=1.0

# ===== Rerank（精排，默认关闭）=====
# 实测 bge-m3 向量召回已足够好，rerank 对民法典短条文场景反而损害排序精度，故默认关闭。
# 设 true 可开启对比（需 SILICONFLOW_API_KEY）。
RERANK_ENABLED=false
RERANK_CANDIDATES=10
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3
