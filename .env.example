# ===== ModelScope（LLM + 可选 embedding）=====
# 在 https://modelscope.cn 的「访问令牌」页面获取
MODELSCOPE_API_KEY=your_modelscope_token_here
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
# LLM 模型（实测可用：deepseek-ai/DeepSeek-V3.2，中文强、免费）
# 可用模型列表见 ModelScope API-Inference 文档
LLM_MODEL=deepseek-ai/DeepSeek-V3.2

# ===== Embedding 供应商切换 =====
# 可选值：modelscope | siliconflow
# 注意：ModelScope 免费 embedding 额度限制较严，实测推荐用 siliconflow
EMBEDDING_PROVIDER=siliconflow

# ModelScope embedding（若其 /v1/embeddings 可用）
MODELSCOPE_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B

# ===== SiliconFlow（embedding 推荐，国内可访问、免费额度充足）=====
# 在 https://cloud.siliconflow.cn 的「API 密钥」页面获取
SILICONFLOW_API_KEY=your_siliconflow_token_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBED_MODEL=BAAI/bge-m3

# ===== 检索参数 =====
TOP_K=5
