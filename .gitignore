# 环境与密钥
.env
*.key

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# 前端依赖与构建产物（镜像内由 Dockerfile 多阶段重新构建）
web/node_modules/
web/dist/

# 向量库与解析数据：随仓库提交以支持创空间部署（冷启动免重建、不耗 embedding 配额）
# 如需保持仓库精简，可重新忽略并改为启动时构建。
# vector_store/
# data/processed/

# query embedding 缓存（运行时本地生成，不入库）
vector_store/_query_cache/

# 用户反馈日志（运行时生成的本地数据，不入库）
data/feedback.jsonl

# 评估/服务运行日志（运行时产物，不入库）
eval/*.log
web_serve.log

# LawRefBook/Laws 法律源仓库：本地克隆用于构建解析，体量大，不随本仓库提交
Laws/

# 本地计划/会话文件
.claude/
memory/
docs/

# IDE
.vscode/
.idea/

